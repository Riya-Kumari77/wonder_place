<% layout('layouts/boilerplate') %>

<div class="d-flex justify-content-center flex-wrap gap-2 mb-4 mt-2">
    <a href="/listings?category=Beach" class="btn btn-outline-secondary rounded-pill shadow-sm"><i class="fa-solid fa-umbrella-beach"></i> Beach</a>
    <a href="/listings?category=Mountain" class="btn btn-outline-secondary rounded-pill shadow-sm"><i class="fa-solid fa-mountain"></i> Mountain</a>
    <a href="/listings?category=Camping" class="btn btn-outline-secondary rounded-pill shadow-sm"><i class="fa-solid fa-campground"></i> Camping</a>
    <a href="/listings?category=Villa" class="btn btn-outline-secondary rounded-pill shadow-sm"><i class="fa-solid fa-house"></i> Villa</a>
    <a href="/listings?category=Apartment" class="btn btn-outline-secondary rounded-pill shadow-sm"><i class="fa-solid fa-building"></i> Apartment</a>
    <a href="/listings?category=Luxury" class="btn btn-outline-secondary rounded-pill shadow-sm"><i class="fa-solid fa-gem"></i> Luxury</a>
    <a href="/listings?category=Budget" class="btn btn-outline-secondary rounded-pill shadow-sm"><i class="fa-solid fa-wallet"></i> Budget</a>
    <a href="/listings" class="btn btn-danger rounded-pill shadow-sm ms-2">Clear</a>
</div>

<% if(allListings.length === 0) { %>
    <div class="alert alert-light text-center shadow-sm p-5 rounded-4 mt-4">
        <h4 class="text-muted"><i class="fa-solid fa-magnifying-glass fs-1 mb-3"></i><br>No results found</h4>
        <p class="text-muted">Try searching for a different destination or checking your spelling.</p>
    </div>
<% } else { %>
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4 mb-5">
        <% for(let listing of allListings) { %>
            <div class="col">
                <a href="/listings/<%= listing._id %>" class="text-decoration-none text-dark">
                    <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden listing-card">
                        <img src="<%= listing.image.url %>" class="card-img-top" alt="<%= listing.title %>" style="height: 250px; object-fit: cover;">
                        <div class="card-body">
                            <h5 class="card-title text-truncate fw-bold mb-1"><%= listing.title %></h5>
                            <p class="card-text text-muted mb-2"><i class="fa-solid fa-location-dot"></i> <%= listing.location %>, <%= listing.country %></p>
                            <p class="card-text fs-5"><span class="fw-bold text-dark">₹<%= listing.price %></span> <span class="fs-6 text-muted">/ night</span></p>
                        </div>
                    </div>
                </a>
            </div>
        <% } %>
    </div>
<% } %>