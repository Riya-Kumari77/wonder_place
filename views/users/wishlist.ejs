<% layout('layouts/boilerplate') %>

<h2 class="fw-bold mt-4 mb-4">My Wishlist</h2>

<% if(allListings.length === 0) { %>
    <div class="alert alert-light text-center shadow-sm p-5 rounded-4 mt-4">
        <h4 class="text-muted"><i class="fa-regular fa-heart fs-1 mb-3"></i><br>Your wishlist is empty</h4>
        <p class="text-muted">Start exploring and save your favorite properties here!</p>
        <a href="/listings" class="btn btn-dark rounded-pill px-4 mt-2">Start Exploring</a>
    </div>
<% } else { %>
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4 mb-5">
        <% for(let listing of allListings) { %>
            <div class="col">
                <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden listing-card position-relative">
                    
                    <form method="POST" action="/wishlist/<%= listing._id %>" class="position-absolute" style="top: 10px; right: 10px; z-index: 5;">
                        <button type="submit" class="btn btn-light rounded-circle shadow-sm" style="width: 35px; height: 35px; padding: 0;">
                            <i class="fa-solid fa-heart text-danger"></i>
                        </button>
                    </form>

                    <a href="/listings/<%= listing._id %>" class="text-decoration-none text-dark">
                        <img src="<%= listing.image.url %>" class="card-img-top" alt="<%= listing.title %>" style="height: 250px; object-fit: cover;">
                        <div class="card-body">
                            <h5 class="card-title text-truncate fw-bold mb-1"><%= listing.title %></h5>
                            <p class="card-text text-muted mb-2"><i class="fa-solid fa-location-dot"></i> <%= listing.location %>, <%= listing.country %></p>
                            <p class="card-text fs-5"><span class="fw-bold text-dark">₹<%= listing.price %></span> <span class="fs-6 text-muted">/ night</span></p>
                        </div>
                    </a>
                </div>
            </div>
        <% } %>
    </div>
<% } %>