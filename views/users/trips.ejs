<% layout('layouts/boilerplate') %>

<h2 class="fw-bold mt-4 mb-4">My Trips</h2>

<% if(bookings.length === 0) { %>
    <div class="alert alert-light text-center shadow-sm p-5 rounded-4 mt-4">
        <h4 class="text-muted"><i class="fa-solid fa-plane-departure fs-1 mb-3"></i><br>No trips booked... yet!</h4>
        <p class="text-muted">Time to dust off your bags and start planning your next adventure.</p>
        <a href="/listings" class="btn btn-brand rounded-pill px-4 mt-2">Start Searching</a>
    </div>
<% } else { %>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 mb-5">
        <% for(let booking of bookings) { %>
            <div class="col">
                <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden">
                    <a href="/listings/<%= booking.listing._id %>" class="text-decoration-none text-dark">
                        <img src="<%= booking.listing.image.url %>" class="card-img-top" style="height: 200px; object-fit: cover;">
                    </a>
                    <div class="card-body p-4">
                        <h5 class="fw-bold text-truncate mb-3"><%= booking.listing.title %></h5>
                        
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted fw-semibold small text-uppercase">Check-in</span>
                            <span class="text-muted fw-semibold small text-uppercase">Checkout</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3 border-bottom pb-3">
                            <span class="fw-bold"><%= booking.checkIn.toDateString().substring(4) %></span>
                            <i class="fa-solid fa-arrow-right text-muted mt-1"></i>
                            <span class="fw-bold"><%= booking.checkOut.toDateString().substring(4) %></span>
                        </div>
                        
                        <p class="mb-1"><i class="fa-solid fa-user-group text-muted me-2"></i> <%= booking.guests %> Guests</p>
                        <p class="mb-3"><i class="fa-solid fa-receipt text-muted me-2"></i> Total: <span class="fw-bold">₹<%= booking.totalPrice %></span></p>
                        
                        <div class="d-grid">
                            <span class="badge bg-success py-2 rounded-pill fs-6"><i class="fa-regular fa-circle-check"></i> <%= booking.status %></span>
                        </div>
                    </div>
                </div>
            </div>
        <% } %>
    </div>
<% } %>